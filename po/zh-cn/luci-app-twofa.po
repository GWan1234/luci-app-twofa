msgstr ""
"Project-Id-Version: luci-app-twofa\n"
"Language: zh_CN\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=1; plural=0;\n"

msgid "Two-Factor Authentication"
msgstr "两步验证 (2FA)"

msgid "Protect your router with TOTP-based 2FA (Google Authenticator, Authy, etc.)."
msgstr "使用基于 TOTP 的两步验证保护您的路由器（兼容 Google 验证器、Authy 等）。"

msgid "Global Settings"
msgstr "全局设置"

msgid "Enable 2FA"
msgstr "启用两步验证"

msgid "Enforce two-factor authentication for OpenWrt Web Interface."
msgstr "强制为 OpenWrt Web 管理界面开启两步验证。"

msgid "Secret Key"
msgstr "密钥"

msgid "Enter this key manually if you cannot scan the QR code."
msgstr "若无法扫描二维码，请手动输入此密钥。"

msgid "QR Code"
msgstr "二维码"

msgid "Scan this with your authenticator app."
msgstr "请使用验证器 App 扫描此二维码。"

msgid "Regenerate Secret"
msgstr "重置密钥"

msgid "Check this and save to generate a new secret key. WARNING: Your old codes will stop working immediately."
msgstr "勾选并保存后将生成新密钥。警告：旧验证码会立即失效。"

msgid "Error: 'qrencode' package is missing. Install: opkg install qrencode"
msgstr "错误：未安装 qrencode。请执行：opkg install qrencode"

msgid "Secret key is not ready yet. Save settings or reload the page."
msgstr "密钥尚未就绪，请保存设置或刷新页面。"

msgid "Failed to generate QR code. Check system log (logread | grep twofa)."
msgstr "二维码生成失败，请查看日志：logread | grep twofa"

msgid "Failed to encode QR image (base64/openssl missing)."
msgstr "二维码图片编码失败（缺少 base64 或 openssl）。"

msgid "2FA Settings"
msgstr "两步验证设置"

msgid "Two-Factor Auth"
msgstr "两步验证"

msgid "Please enter your 6-digit TOTP code to continue."
msgstr "请输入验证器中的 6 位动态验证码以继续。"

msgid "Invalid format"
msgstr "格式无效"

msgid "Verifying..."
msgstr "正在验证…"

msgid "Invalid verification code"
msgstr "验证码错误"

msgid "Verify"
msgstr "验证"
