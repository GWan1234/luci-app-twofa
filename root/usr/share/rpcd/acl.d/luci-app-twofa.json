{
	"luci-app-twofa": {
		"description": "Grants access to the 2FA settings page and the luci.twofa ubus object. Must be attached to every login that is required to satisfy 2FA.",
		"read": {
			"ubus": {
				"luci.twofa": [ "status", "verify" ]
			},
			"file": {
				"/etc/config/twofa": [ "read" ],
				"/var/run/luci-twofa-sessions.json": [ "read" ]
			},
			"uci": [ "twofa" ]
		},
		"write": {
			"ubus": {
				"luci.twofa": [ "status", "verify" ]
			},
			"file": {
				"/etc/config/twofa": [ "write" ],
				"/var/run/luci-twofa-sessions.json": [ "write" ]
			},
			"uci": [ "twofa" ]
		}
	}
}
