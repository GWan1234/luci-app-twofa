#!/usr/bin/lua
-- rpcd plugin: exposes ubus object `luci-app-twofa` with methods `status`,
-- `verify`, and `regenerate`. This plugin is the single point of TOTP
-- enforcement: when an authenticated session has not yet satisfied 2FA,
-- status() revokes every non-allow-listed ACL on the session, so subsequent
-- ubus calls (uci.set, network.*, etc.) are denied by rpcd itself.
--
-- NOTE on naming: rpcd registers each /usr/libexec/rpcd/<basename> script
-- as a ubus object using the basename verbatim. This file is named
-- `luci-app-twofa`, so the ubus object name is also `luci-app-twofa`,
-- NOT `luci.twofa`. The ACL file, the JS preload, the guard daemon and the
-- PRESERVE table below all use this exact name; do not "tidy" it.
--
-- Security model (v1.0-r16):
--
--   * Brute force: verify() enforces 5 failed attempts -> 1-min lockout,
--     doubling each lockout up to 30 min. Counters survive downgrade() so
--     an attacker cannot reset by triggering re-downgrade.
--
--   * Replay: every successful verify records the matched TOTP counter on
--     the session record. Subsequent verifies with a counter <= the last
--     one are rejected as totp_replayed. This implements RFC 6238 §5.2.
--
--   * Side channels: token comparison uses totp.verify_window, which
--     evaluates all candidate codes in fixed order with constant-time byte
--     compare, so neither which time slot matched nor any token prefix
--     leaks through wall-clock timing.
--
--   * Token leakage at rest: session keys in /var/run/luci-twofa-sessions
--     .json are SHA-256 hashes of the raw SID. A file leak yields opaque
--     hashes, not live bearer tokens.
--
--   * Atomic state writes: the state file is created via mktemp + chmod
--     0600 BEFORE any content is written and then atomically renamed onto
--     the live path, so there is never a world-readable window.
--
-- The downgrade still relies on status() being called for every fresh
-- session. The browser preload does this immediately on page load, but
-- non-browser API clients (curl, Python, etc.) never would. That gap is
-- closed by /usr/sbin/luci-app-twofa-guardd (procd-managed), which polls
-- `session list` and invokes status() on every SID within ~1s.

local json = require "luci.jsonc"
local fs   = require "nixio.fs"

local function safe_require(mod)
	local ok, m = pcall(require, mod)
	return ok and m or nil
end

local totp  = safe_require("luci.twofa.totp")
local nixio = safe_require("nixio")

-- ---------------------------------------------------------------------------
-- Tunables
-- ---------------------------------------------------------------------------

local STATE_FILE   = "/var/run/luci-twofa-sessions.json"
local SECRET_FILE  = "/etc/twofa.secret"
local STATE_TTL    = 86400
local MAX_ATTEMPTS = 5
local LOCKOUT_BASE = 60       -- seconds: 1st engagement is 60s
local LOCKOUT_CAP  = 1800     -- 30 min ceiling on exponential backoff
local TOTP_WINDOW  = 1        -- accept slots [-1, 0, +1]

-- Explicit (scope, object, method) allow list of what stays callable on a
-- downgraded (unverified) session. EVERYTHING else gets revoked. The old
-- code preserved every method on `session` wholesale, which left
-- session.grant / session.destroy / session.create reachable; the new list
-- pins them to access() only (LuCI's heartbeat).
local PRESERVE = {
	ubus = {
		["luci-app-twofa"] = { status = true, verify = true },
		["session"]        = { access = true },
	},
}

local function should_preserve(it)
	local objs = PRESERVE[it.scope]
	if not objs then return false end
	local fns = objs[it.obj]
	return fns ~= nil and fns[it.fn] == true
end

-- ---------------------------------------------------------------------------
-- Hashing / SID anonymisation
-- ---------------------------------------------------------------------------

local function to_hex(s)
	return (s:gsub(".", function(c) return string.format("%02x", c:byte()) end))
end

local function sid_key(sid)
	if not sid or sid == "" then return "" end
	-- Prefer SHA-256 via nixio.crypto when present.
	if nixio and nixio.crypto and nixio.crypto.hash then
		local ok, h = pcall(nixio.crypto.hash, "sha256", sid)
		if ok and type(h) == "string" and #h > 0 then return h end
	end
	-- Fall back to the totp module's pure-Lua SHA-1: 160 bits is more than
	-- enough for "irreversible session record key". Always available because
	-- we ship the implementation.
	if totp and totp._sha1 then
		local ok, raw = pcall(totp._sha1, sid)
		if ok and raw then return to_hex(raw) end
	end
	-- Last resort: never store the raw SID. Embed length so collisions are
	-- impossible across different SIDs of different lengths.
	return string.format("unh-%d-%s", #sid, sid:sub(1, 8) .. sid:sub(-8))
end

local function sid_tag(sid)
	local k = sid_key(sid or "")
	if k == "" then return "?" end
	return k:sub(1, 8)
end

-- ---------------------------------------------------------------------------
-- State file - atomic, 0600 before any data touches disk
-- ---------------------------------------------------------------------------

local function read_state()
	local f = io.open(STATE_FILE, "rb")
	if not f then return { sessions = {} } end
	local data = f:read("*a") or ""
	f:close()
	if data == "" then return { sessions = {} } end
	local parsed = json.parse(data)
	if type(parsed) ~= "table" then return { sessions = {} } end
	parsed.sessions = parsed.sessions or {}
	return parsed
end

local function write_state(state)
	state = state or { sessions = {} }
	local now = os.time()
	for k, info in pairs(state.sessions or {}) do
		if type(info) ~= "table" or (info.expires and info.expires < now) then
			state.sessions[k] = nil
		end
	end

	-- Write to a sibling temp file, chmod 0600 BEFORE writing content, then
	-- atomically rename onto the live path. fs.writefile() (the old approach)
	-- created with default umask -> typically 0644, leaving a microsecond
	-- window where the file was world-readable.
	local tmp = STATE_FILE .. ".tmp"
	local f = io.open(tmp, "w")
	if not f then return end
	pcall(fs.chmod, tmp, tonumber("600", 8))
	f:write(json.stringify(state))
	f:close()
	os.rename(tmp, STATE_FILE)
end

-- ---------------------------------------------------------------------------
-- Shell helpers - quote EVERY argument even when current callers pass
-- constants. Cheap insurance against a future refactor accidentally
-- introducing command injection.
-- ---------------------------------------------------------------------------

local function shellquote(s)
	return "'" .. tostring(s or ""):gsub("'", "'\\''") .. "'"
end

local function log(msg)
	os.execute("logger -t luci-app-twofa " .. shellquote(tostring(msg)))
end

local function ubus_call(object, method, args)
	local payload = json.stringify(args or {})
	local cmd = string.format("ubus call %s %s %s 2>/dev/null",
		shellquote(object), shellquote(method), shellquote(payload))
	local p = io.popen(cmd)
	if not p then return nil end
	local out = p:read("*a") or ""
	p:close()
	if out == "" then return nil end
	local parsed = json.parse(out)
	return (type(parsed) == "table") and parsed or nil
end

local function uci_get(config, section, option)
	local key = string.format("%s.%s.%s", config, section, option)
	local cmd = "uci -q get " .. shellquote(key) .. " 2>/dev/null"
	local p = io.popen(cmd)
	if not p then return nil end
	local v = p:read("*l")
	p:close()
	if v == nil or v == "" then return nil end
	return v
end

-- ---------------------------------------------------------------------------
-- Configuration
-- ---------------------------------------------------------------------------

local function read_secret()
	-- Secret lives outside UCI now. See uci-defaults/10-luci-app-twofa for
	-- migration history.
	local f = io.open(SECRET_FILE, "rb")
	if not f then return nil end
	local data = f:read("*l") or ""
	f:close()
	data = data:gsub("%s+", "")
	if #data < 16 then return nil end
	return data
end

local function is_enabled()
	return uci_get("twofa", "global", "enabled") == "1"
end

local function is_configured()
	return read_secret() ~= nil
end

-- ---------------------------------------------------------------------------
-- ACL downgrade / restore
-- ---------------------------------------------------------------------------

local function flatten_acls(acls)
	local out = {}
	if type(acls) ~= "table" then return out end
	for scope, scope_data in pairs(acls) do
		if type(scope_data) == "table" then
			for obj, funcs in pairs(scope_data) do
				if type(funcs) == "table" then
					for _, fn in ipairs(funcs) do
						out[#out + 1] = { scope = scope, obj = obj, fn = fn }
					end
				end
			end
		end
	end
	return out
end

local function apply_acl_op(verb, sid, items)
	if not items or #items == 0 then return end
	local by_scope = {}
	for _, it in ipairs(items) do
		by_scope[it.scope] = by_scope[it.scope] or {}
		table.insert(by_scope[it.scope], { it.obj, it.fn })
	end
	for scope, objects in pairs(by_scope) do
		ubus_call("session", verb, {
			ubus_rpc_session = sid,
			scope            = scope,
			objects          = objects,
		})
	end
end

local function downgrade(sid)
	if not sid or sid == "" then return end
	local hk    = sid_key(sid)
	local state = read_state()
	local cur   = state.sessions[hk]
	if cur and cur.verified ~= true and type(cur.saved_acls) == "table"
	   and #cur.saved_acls > 0 then
		-- Already downgraded; refresh expiry and re-apply ACL revocations
		-- in case rpcd was restarted and lost in-memory grant state.
		cur.expires = os.time() + STATE_TTL
		write_state(state)
		apply_acl_op("revoke", sid, cur.saved_acls)
		return
	end

	local sess = ubus_call("session", "list", { ubus_rpc_session = sid })
	if not sess or type(sess.acls) ~= "table" then return end

	local saved = {}
	for _, it in ipairs(flatten_acls(sess.acls)) do
		if not should_preserve(it) then
			saved[#saved + 1] = it
		end
	end

	-- Preserve rate-limit counters across downgrade so an attacker cannot
	-- reset their attempt budget by re-triggering downgrade (which they can
	-- do simply by calling status() again).
	local prev = state.sessions[hk] or {}
	state.sessions[hk] = {
		verified     = false,
		saved_acls   = saved,
		expires      = os.time() + STATE_TTL,
		attempts     = prev.attempts     or 0,
		fails        = prev.fails        or 0,
		lock_until   = prev.lock_until,
		last_counter = prev.last_counter,
	}
	write_state(state)
	apply_acl_op("revoke", sid, saved)
end

local function restore(sid, matched_counter)
	if not sid or sid == "" then return false end
	local hk    = sid_key(sid)
	local state = read_state()
	local cur   = state.sessions[hk] or {}
	if type(cur.saved_acls) == "table" then
		apply_acl_op("grant", sid, cur.saved_acls)
	end
	state.sessions[hk] = {
		verified     = true,
		saved_acls   = nil,
		expires      = os.time() + STATE_TTL,
		last_counter = matched_counter,
	}
	write_state(state)
	return true
end

-- ---------------------------------------------------------------------------
-- ubus methods
-- ---------------------------------------------------------------------------

local function method_status(args)
	local sid        = args.ubus_rpc_session
	local enabled    = is_enabled()
	local configured = is_configured()

	local state      = read_state()
	local sess_state = state.sessions[sid_key(sid or "")] or {}
	local verified   = sess_state.verified == true

	if enabled and configured and sid and not verified then
		downgrade(sid)
	end

	return {
		enabled    = enabled,
		configured = configured,
		verified   = (not enabled) or verified,
	}
end

local function method_verify(args)
	local sid    = args.ubus_rpc_session
	local raw    = tostring(args.token or "")
	local token  = (raw:gsub("%s+", ""))
	local tag    = sid_tag(sid)

	if not sid or sid == "" then
		log("verify denied: no_session")
		return { success = false, error = "no_session" }
	end
	if not token:match("^%d%d%d%d%d%d$") then
		log(string.format("verify denied [%s]: bad_format raw_len=%d",
			tag, #raw))
		return { success = false, error = "bad_format" }
	end
	if not is_enabled() then
		log(string.format("verify allowed [%s]: 2fa disabled", tag))
		return { success = true }
	end
	if not totp then
		log(string.format("verify denied [%s]: totp_module_missing", tag))
		return { success = false, error = "totp_module_missing" }
	end

	local secret = read_secret()
	if not secret then
		log(string.format("verify denied [%s]: no_secret", tag))
		return { success = false, error = "no_secret" }
	end

	local hk    = sid_key(sid)
	local state = read_state()
	local rec   = state.sessions[hk] or {}
	local now   = os.time()

	-- Rate-limit gate FIRST so a locked-out attacker burns no CPU on HMAC
	-- and gets no oracle from differential timing.
	if rec.lock_until and rec.lock_until > now then
		log(string.format(
			"verify denied [%s]: rate_limited retry_after=%d",
			tag, rec.lock_until - now))
		return {
			success     = false,
			error       = "rate_limited",
			retry_after = rec.lock_until - now,
		}
	end

	log(string.format("verify [%s]: hmac_backend=%s",
		tag, tostring(totp._hmac_backend or "unknown")))

	local ok, matched, matched_counter = pcall(
		totp.verify_window, secret, token, TOTP_WINDOW)
	if not ok then
		log(string.format("verify crashed [%s]: %s", tag, tostring(matched)))
		return { success = false, error = "totp_exception",
		         detail  = tostring(matched) }
	end

	-- Replay protection: every successful counter must be strictly greater
	-- than the last successful one we recorded for this session record.
	-- (rec is keyed by sid_key, so it persists across the verify -> restore
	-- transition.)
	if matched and rec.last_counter and matched_counter
	   and matched_counter <= rec.last_counter then
		rec.attempts = (rec.attempts or 0) + 1
		state.sessions[hk] = rec
		write_state(state)
		log(string.format(
			"verify denied [%s]: totp_replayed counter=%d prev=%d",
			tag, matched_counter, rec.last_counter))
		return { success = false, error = "totp_replayed" }
	end

	if not matched then
		rec.attempts = (rec.attempts or 0) + 1
		if rec.attempts >= MAX_ATTEMPTS then
			local exp = math.min(LOCKOUT_CAP,
				LOCKOUT_BASE * (2 ^ math.min(5, rec.fails or 0)))
			rec.lock_until = now + exp
			rec.fails      = (rec.fails or 0) + 1
			rec.attempts   = 0
			log(string.format(
				"verify denied [%s]: rate_limit_engaged lock=%ds fails=%d",
				tag, exp, rec.fails))
		end
		state.sessions[hk] = rec
		write_state(state)
		log(string.format(
			"verify denied [%s]: totp_mismatch slot=%d attempts=%d",
			tag, math.floor(now / 30), rec.attempts))
		return { success = false, error = "totp_mismatch" }
	end

	restore(sid, matched_counter)
	log(string.format("verify ok [%s]: counter=%d", tag, matched_counter or -1))
	return { success = true }
end

-- regenerate: writes a fresh secret file by shelling out to twofa-genkey,
-- then wipes the session state so every existing session must re-verify
-- against the new secret. Reserved for callers that have already passed
-- 2FA (the method is NOT in PRESERVE, so a downgraded session cannot
-- invoke it).
local function method_regenerate(args)
	local tag = sid_tag(args.ubus_rpc_session)
	local rc  = os.execute("/usr/sbin/twofa-genkey >/dev/null 2>&1")
	local ok  = (rc == 0) or (rc == true)
	if not ok then
		log(string.format("regenerate failed [%s]: genkey rc=%s",
			tag, tostring(rc)))
		return { success = false, error = "genkey_failed" }
	end
	write_state({ sessions = {} })
	log(string.format("regenerate ok [%s]: state wiped", tag))
	return { success = true }
end

local methods = {
	status     = { args = {},             call = method_status     },
	verify     = { args = { token = "" }, call = method_verify     },
	regenerate = { args = {},             call = method_regenerate },
}

-- ---------------------------------------------------------------------------
-- rpcd glue
-- ---------------------------------------------------------------------------

local function json_string(s)
	return '"' .. tostring(s):gsub('\\', '\\\\'):gsub('"', '\\"') .. '"'
end

local cmd = arg[1]

if cmd == "list" then
	-- Hand-roll the JSON: luci.jsonc serialises an empty Lua table as `[]`,
	-- but rpcd expects each method definition to be an OBJECT (`{}`), even
	-- when it takes no arguments.
	local entries = {}
	for name, def in pairs(methods) do
		local arg_parts = {}
		for k, v in pairs(def.args or {}) do
			arg_parts[#arg_parts + 1] = json_string(k) .. ":" .. json_string(v)
		end
		entries[#entries + 1] = json_string(name)
			.. ":{" .. table.concat(arg_parts, ",") .. "}"
	end
	io.write("{" .. table.concat(entries, ",") .. "}")
elseif cmd == "call" then
	local name = arg[2]
	local m    = methods[name]
	if not m then
		io.write('{"error":"unknown_method"}')
		os.exit(1)
	end

	local raw   = io.read("*a") or "{}"
	local input = json.parse(raw)
	if type(input) ~= "table" then input = {} end

	local ok, res = pcall(m.call, input)
	if not ok then
		io.stderr:write("luci-app-twofa rpcd: " .. tostring(res) .. "\n")
		io.write('{"error":"internal"}')
		os.exit(1)
	end

	io.write(json.stringify(res or {}))
end
